{
    "name": "access-logger/access-logger",
    "description": "Open-source web telemetry microservice (fingerprints, pageviews, events)",
    "type": "project",
    "license": "MIT",
    "require": {
        "php": ">=8.2",
        "slim/slim": "^4.14",
        "slim/psr7": "^1.7"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "AccessLogger\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "AccessLogger\\Tests\\": "tests/"
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "php-http/discovery": true
        }
    }
}
